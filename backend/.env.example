# Example environment variables for the backend
# Copy this file to .env and fill the values before running locally or deploying.

# Postgres database URL (Prisma expects a DATABASE_URL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# JWT secret used for signing tokens
JWT_SECRET=5c987576589bbacb5cc93a7136ef3de900e52fe910bb72e42947b73e223cc20c

# Server port
PORT=5000

# Node environment
NODE_ENV=development
